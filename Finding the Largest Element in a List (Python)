def largest(arr):
    if len(arr) == 0:
        raise ValueError("Array is empty")

    largest = arr[0]

    for i in range(1, len(arr)):
        if arr[i] > largest:
            largest = arr[i]

    return largest


# Example usage
arr = [10, 25, 5, 40, 15]
print("Largest element:", largest(arr))
