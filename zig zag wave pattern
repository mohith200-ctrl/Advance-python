n = 5

# Upper Part
for i in range(1, n + 1):
    for j in range(1, n + 1):
        if j == i:
            print("*", end=" ")
        else:
            print(" ", end=" ")
    print()

# Lower Part
for i in range(n - 1, 0, -1):
    for j in range(1, n + 1):
        if j == i:
            print("*", end=" ")
        else:
            print(" ", end=" ")
    print()
